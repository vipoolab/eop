{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "functions": {
    "app/api/commands/draft/letter/route.ts": { "maxDuration": 60 },
    "app/api/commands/draft/alignment/route.ts": { "maxDuration": 60 },
    "app/api/commands/draft/kpis/route.ts": { "maxDuration": 60 },
    "app/api/commands/docx/route.ts": { "maxDuration": 30 },
    "app/api/intelligence/classify/route.ts": { "maxDuration": 60 },
    "app/api/intelligence/classify/batch/route.ts": { "maxDuration": 60 },
    "app/api/intelligence/ocr/route.ts": { "maxDuration": 60 },
    "app/api/search/route.ts": { "maxDuration": 30 }
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
