# ─────────────────────────────────────────────
# EOP — Environment Variables
# ─────────────────────────────────────────────

# Neon Postgres connection string
# Get from: https://console.neon.tech/ → New Project → Copy connection string
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/eop?sslmode=require"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="changeme-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Anthropic Claude API (สำหรับ AI Command Drafting + Doc Classification)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Optional — Together AI (สำรอง)
TOGETHER_API_KEY=""

# OCR provider — placeholder for Phase 2
OCR_PROVIDER="mock" # mock | paddleocr | typhoon-vision
