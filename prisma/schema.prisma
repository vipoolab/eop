  BIOMETRIC
  ANALYTICS
}

// ═══════════════════════════════════════════════════════════════
// A. IDENTITY & ACCESS (TOR 7.1, 5.5) — 8 models
// ═══════════════════════════════════════════════════════════════

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  rank         String?
  position     String?
  badgeNo      String?   @unique
  passwordHash String
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  mfaRecoveryCodes   String[]  @default([])  // hashed recovery codes (one-time use)
  mfaEnabledAt       DateTime?
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  unitId       String?
  unit         Unit?     @relation(fields: [unitId], references: [id])
  role         UserRole  @default(STAFF)
  roleId       String?
  customRole   Role?     @relation(fields: [roleId], references: [id])
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions                  Session[]
  mobileDevices             MobileDevice[]
  commandsCreated           Command[]               @relation("CommandCreator")
  commandsSigned            Command[]               @relation("CommandSigner")
  commandComments           CommandComment[]
  commandTargetsAssigned    CommandTarget[]
  digitalSignatures         DigitalSignature[]
  notifications             Notification[]
  escalationRulesTarget     EscalationRule[]        @relation("EscalationToUser")
  escalationLogs            EscalationLog[]
  missionsOwned             Mission[]
  missionTargets            MissionTarget[]
  missionEvents             MissionEvent[]
  agendasOwned              Agenda[]
  documents                 Document[]
  ocrJobs                   OcrJob[]
  formSubmissionsByUser     FormSubmission[]        @relation("FormSubmittedBy")
  formSubmissionsReviewed   FormSubmission[]        @relation("FormReviewedBy")
  formTemplatesCreated      FormTemplate[]
  commandTemplatesCreated   CommandTemplate[]
  complianceReportsCreated  ComplianceReport[]      @relation("CompReportCreator")
  complianceReportsReviewed ComplianceReport[]      @relation("CompReportReviewer")
  complianceReportsApproved ComplianceReport[]      @relation("CompReportApprover")
  complianceAnswers         ComplianceAnswer[]
  complianceScoreLogs       ComplianceScoreLog[]
  alignmentChecks           AlignmentCheck[]
  planImports               PlanImport[]
  plansCreated              StrategicPlan[]
  policyDirectives          PolicyDirective[]
  kpisOwned                 Kpi[]
  kpiResultsReported        KpiResult[]
  aiTrainingDocs            AiTrainingDocument[]
  aiPromptTemplates         AiPromptTemplate[]
  aiModelRuns               AiModelRun[]
  aiEvaluations             AiEvaluation[]
  etlJobsCreated            EtlJob[]
  savedDashboards           SavedDashboard[]
  searchHistory             SearchHistory[]
  savedQueries              SavedQuery[]
  executiveSummaries        ExecutiveSummary[]
  situationReports          SituationReport[]
  afterActionReviews        AfterActionReview[]
  anomalyAlertsAck          AnomalyAlert[]
  resourceAllocations       ResourceAllocation[]
  incidentsResponded        Incident[]
  auditLogs                 AuditLog[]
  consentRecords            ConsentRecord[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model LoginAttempt {
  id         String           @id @default(cuid())
  email      String
  success    Boolean
  failReason LoginFailReason?
  ipAddress  String
  userAgent  String?
  createdAt  DateTime         @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model Unit {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  level       UnitLevel @default(STATION)
  type        UnitType?
  latitude    Float?
  longitude   Float?
  address     String?
  phone       String?
  parentId    String?
  parent      Unit?     @relation("UnitHierarchy", fields: [parentId], references: [id])
  children    Unit[]    @relation("UnitHierarchy")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users               User[]
  missions            Mission[]
  missionTargets      MissionTarget[]
  commandTargets      CommandTarget[]
  documents           Document[]
  agendas             Agenda[]
  kpiResults          KpiResult[]
  complianceReports   ComplianceReport[]
  formSubmissions     FormSubmission[]
  savedDashboards     SavedDashboard[]
  executiveSummaries  ExecutiveSummary[]
  situationReports    SituationReport[]
  resourceAssets      ResourceAsset[]
  resourceAllocations ResourceAllocation[]
  incidentsAssigned   Incident[]
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  users           User[]
  rolePermissions RolePermission[]
  escalationRules EscalationRule[]
}

model Permission {
  id          String  @id @default(cuid())
  code        String  @unique
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model MobileDevice {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   MobilePlatform
  pushToken  String
  deviceName String?
  osVersion  String?
  appVersion String?
  lastSeenAt DateTime       @default(now())
  active     Boolean        @default(true)

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// B. STRATEGIC PLAN (TOR 5.4.1 / 1.1-1.3) — 7 models
// ═══════════════════════════════════════════════════════════════

model StrategicPlan {
  id           String          @id @default(cuid())
  level        PlanLevel
  code         String
  title        String
  description  String?
  /// เจตนาของผู้ใช้นโยบาย — TOR 1.2.1 AI Draft Recommendation
  policyIntent String?
  source       PlanSource      @default(MANUAL)
  importId     String?
  importJob    PlanImport?     @relation(fields: [importId], references: [id])
  parentId     String?
  parent       StrategicPlan?  @relation("PlanHierarchy", fields: [parentId], references: [id])
  children     StrategicPlan[] @relation("PlanHierarchy")
  status       PlanStatus      @default(ACTIVE)
  startDate    DateTime?
  endDate      DateTime?
  createdById  String?
  createdBy    User?           @relation(fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  kpis           Kpi[]
  missions       Mission[]
  sourceLinkages PlanLinkage[] @relation("PlanLinkageSource")
  targetLinkages PlanLinkage[] @relation("PlanLinkageTarget")

  @@index([level])
  @@index([parentId])
}

model PlanImport {
  id              String       @id @default(cuid())
  sourceFile      String
  sourceFormat    ImportFormat
  importedById    String
  importedBy      User         @relation(fields: [importedById], references: [id])
  status          ImportStatus @default(PENDING)
  recordsImported Int          @default(0)
  errorLog        String?      @db.Text
  createdAt       DateTime     @default(now())
  finishedAt      DateTime?

  plans StrategicPlan[]

  @@index([status, createdAt])
}

model PolicyDirective {
  id            String   @id @default(cuid())
  year          Int
  issuedById    String
  issuedBy      User     @relation(fields: [issuedById], references: [id])
  title         String
  content       String   @db.Text
  effectiveDate DateTime
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([year, active])
}

model Kpi {
  id              String          @id @default(cuid())
  planId          String
  plan            StrategicPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  missionId       String?
  mission         Mission?        @relation(fields: [missionId], references: [id])
  code            String
  name            String
  description     String?
  target          Float
  actual          Float           @default(0)
  unit            String?
  period          String?
  status          String?
  measurementType MeasurementType @default(QUANTITATIVE)
  ownerId         String?
  owner           User?           @relation(fields: [ownerId], references: [id])
  updatedAt       DateTime        @updatedAt

  results           KpiResult[]
  missionKpis       MissionKpi[]
  commandTargetKpis CommandTargetKpi[]

  @@index([planId])
}

model KpiResult {
  id            String    @id @default(cuid())
  kpiId         String
  kpi           Kpi       @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  area          String
  period        String
  unitId        String?
  unit          Unit?     @relation(fields: [unitId], references: [id])
  actual        Float
  target        Float
  reportedById  String?
  reportedBy    User?     @relation(fields: [reportedById], references: [id])
  evidenceDocId String?
  evidenceDoc   Document? @relation(fields: [evidenceDocId], references: [id])
  createdAt     DateTime  @default(now())

  @@unique([kpiId, area, period, unitId])
  @@index([kpiId])
  @@index([unitId])
}

model PlanLinkage {
  id           String        @id @default(cuid())
  sourcePlanId String
  sourcePlan   StrategicPlan @relation("PlanLinkageSource", fields: [sourcePlanId], references: [id], onDelete: Cascade)
  targetPlanId String
  targetPlan   StrategicPlan @relation("PlanLinkageTarget", fields: [targetPlanId], references: [id], onDelete: Cascade)
  linkType     LinkageType
  strength     Float         @default(1.0)
  analyzedBy   String        @default("manual") // "ai" | "manual"
  createdAt    DateTime      @default(now())

  @@unique([sourcePlanId, targetPlanId, linkType])
  @@index([sourcePlanId])
}

model AlignmentCheck {
  id          String          @id @default(cuid())
  targetType  AlignmentTarget
  sourceId    String
  referenceId String
  score       Float
  gaps        String[]
  suggestions String[]
  rationale   String          @db.Text
  model       String
  tokensUsed  Int             @default(0)
  elapsedMs   Int             @default(0)
  createdById String?
  createdBy   User?           @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([targetType, sourceId])
  @@index([referenceId])
}

// ═══════════════════════════════════════════════════════════════
// C. AGENDA & MISSION (TOR 5.4.2 / 2.1-2.3) — 9 models
// ═══════════════════════════════════════════════════════════════

model Agenda {
  id            String     @id @default(cuid())
  code          String     @unique
  title         String
  description   String?
  agendaType    AgendaType
  scheduledDate DateTime
  ownerId       String?
  owner         User?      @relation(fields: [ownerId], references: [id])
  unitId        String?
  unit          Unit?      @relation(fields: [unitId], references: [id])
  status        String     @default("scheduled") // scheduled/done/postponed/cancelled
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  missions Mission[]
  commands Command[]

  @@index([scheduledDate])
}

model Mission {
  id          String           @id @default(cuid())
  code        String           @unique
  title       String
  description String?
  goals       String[]
  scope       String?          @db.Text
  caseType    MissionCaseType?
  ownerId     String?
  owner       User?            @relation(fields: [ownerId], references: [id])
  unitId      String?
  unit        Unit?            @relation(fields: [unitId], references: [id])
  planId      String?
  plan        StrategicPlan?   @relation(fields: [planId], references: [id])
  agendaId    String?
  agenda      Agenda?          @relation(fields: [agendaId], references: [id])
  priority    MissionPriority  @default(NORMAL)
  status      MissionStatus    @default(ACTIVE)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  commands            Command[]
  targets             MissionTarget[]
  kpiLinks            MissionKpi[]
  events              MissionEvent[]
  kpis                Kpi[]
  resourceAllocations ResourceAllocation[]
  notifications       Notification[]
  escalationLogs      EscalationLog[]
  attachments         MissionAttachment[]
  formSubmissions     FormSubmission[]
  incidents           Incident[]
  afterActionReviews  AfterActionReview[]

  @@index([status])
  @@index([unitId])
}

model MissionTarget {
  id             String    @id @default(cuid())
  missionId      String
  mission        Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit      @relation(fields: [unitId], references: [id])
  assignedUserId String?
  assignedUser   User?     @relation(fields: [assignedUserId], references: [id])
  status         String    @default("active")
  dueDate        DateTime?
  resultNote     String?   @db.Text
  completedAt    DateTime?

  @@unique([missionId, unitId])
  @@index([unitId])
}

model MissionKpi {
  id              String          @id @default(cuid())
  missionId       String
  mission         Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  kpiId           String
  kpi             Kpi             @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  weight          Float           @default(1.0)
  measurementType MeasurementType @default(QUANTITATIVE)

  @@unique([missionId, kpiId])
}

model MissionEvent {
  id          String           @id @default(cuid())
  missionId   String
  mission     Mission          @relation(fields: [missionId], references: [id], onDelete: Cascade)
  eventType   MissionEventType
  title       String
  description String?
  occurredAt  DateTime
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())

  @@index([missionId, occurredAt])
}

model MissionAttachment {
  id          String   @id @default(cuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  order       Int      @default(0)
  description String?

  @@unique([missionId, documentId])
  @@index([missionId])
}

model FormTemplate {
  id          String           @id @default(cuid())
  name        String
  description String?
  schema      Json
  category    String?
  frequency   ReportFrequency?
  dimensions  String[]
  isSystem    Boolean          @default(false)
  active      Boolean          @default(true)
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  fields      FormField[]
  submissions FormSubmission[]
}

model FormField {
  id            String        @id @default(cuid())
  templateId    String
  template      FormTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parentFieldId String?
  parentField   FormField?    @relation("FormFieldHierarchy", fields: [parentFieldId], references: [id])
  childFields   FormField[]   @relation("FormFieldHierarchy")
  order         Int           @default(0)
  label         String
  fieldType     FormFieldType
  required      Boolean       @default(false)
  placeholder   String?
  validation    Json?

  options FormFieldOption[]

  @@index([templateId, order])
  @@index([parentFieldId])
}

model FormFieldOption {
  id      String    @id @default(cuid())
  fieldId String
  field   FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  order   Int       @default(0)
  value   String
  label   String

  @@index([fieldId, order])
}

model FormSubmission {
  id            String           @id @default(cuid())
  templateId    String
  template      FormTemplate     @relation(fields: [templateId], references: [id])
  data          Json
  unitId        String?
  unit          Unit?            @relation(fields: [unitId], references: [id])
  missionId     String?
  mission       Mission?         @relation(fields: [missionId], references: [id])
  commandId     String?
  command       Command?         @relation(fields: [commandId], references: [id])
  status        SubmissionStatus @default(DRAFT)
  submittedById String?
  submittedBy   User?            @relation("FormSubmittedBy", fields: [submittedById], references: [id])
  reviewedById  String?
  reviewedBy    User?            @relation("FormReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())

  @@index([templateId, status])
  @@index([missionId])
  @@index([commandId])
}

// ═══════════════════════════════════════════════════════════════
// D. COMMAND & WORKFLOW (TOR 5.4.4 / 4.1-4.9) — 11 models
// ═══════════════════════════════════════════════════════════════

model Command {
  id            String           @id @default(cuid())
  docNo         String           @unique
  subject       String
  recipient     String
  reference     String?
  objective     String?
  body          String           @db.Text
  signature     String?
  status        CommandStatus    @default(DRAFT)
  priority      MissionPriority  @default(NORMAL)
  caseType        CommandCaseType?
  emergencyMode   Boolean          @default(false)
  emergencyReason String?          @db.Text
  parentCommandId String?
  parentCommand   Command?         @relation("CommandHierarchy", fields: [parentCommandId], references: [id])
  subCommands     Command[]        @relation("CommandHierarchy")
  missionId       String?
  mission         Mission?         @relation(fields: [missionId], references: [id])
  agendaId        String?
  agenda          Agenda?          @relation(fields: [agendaId], references: [id])
  templateId      String?
  template        CommandTemplate? @relation(fields: [templateId], references: [id])
  creatorId       String
  creator         User             @relation("CommandCreator", fields: [creatorId], references: [id])
  signerId        String?
  signer          User?            @relation("CommandSigner", fields: [signerId], references: [id])
  aiAssisted      Boolean          @default(false)
  aiPromptUsed    String?          @db.Text
  effectiveDate   DateTime?
  dueDate         DateTime?
  publishedAt     DateTime?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  targets             CommandTarget[]
  statusLog           CommandStatusLog[]
  signatures          DigitalSignature[]
  comments            CommandComment[]
  attachments         CommandAttachment[]
  notifications       Notification[]
  escalationLogs      EscalationLog[]
  afterActionReviews  AfterActionReview[]
  formSubmissions     FormSubmission[]
  incidents           Incident[]

  @@index([status])
  @@index([creatorId])
  @@index([caseType])
}

model CommandTemplate {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  caseType    CommandCaseType
  body        String          @db.Text
  isSystem    Boolean         @default(false)
  active      Boolean         @default(true)
  createdById String?
  createdBy   User?           @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())

  commands Command[]
}

model CommandAttachment {
  id          String   @id @default(cuid())
  commandId   String
  command     Command  @relation(fields: [commandId], references: [id], onDelete: Cascade)
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  order       Int      @default(0)
  description String?

  @@unique([commandId, documentId])
  @@index([commandId])
}

model CommandComment {
  id          String      @id @default(cuid())
  commandId   String
  command     Command     @relation(fields: [commandId], references: [id], onDelete: Cascade)
  authorId    String
  author      User        @relation(fields: [authorId], references: [id])
  commentType CommentType
  body        String      @db.Text
  createdAt   DateTime    @default(now())

  @@index([commandId, createdAt])
}

model CommandTarget {
  id             String    @id @default(cuid())
  commandId      String
  command        Command   @relation(fields: [commandId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit      @relation(fields: [unitId], references: [id])
  assignedUserId String?
  assignedUser   User?     @relation(fields: [assignedUserId], references: [id])
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  completed      Boolean   @default(false)
  completedAt    DateTime?
  resultNote     String?   @db.Text

  kpiTargets CommandTargetKpi[]

  @@unique([commandId, unitId])
  @@index([unitId])
}

model CommandTargetKpi {
  id              String        @id @default(cuid())
  commandTargetId String
  commandTarget   CommandTarget @relation(fields: [commandTargetId], references: [id], onDelete: Cascade)
  kpiId           String
  kpi             Kpi           @relation(fields: [kpiId], references: [id])
  targetValue     Float
  actualValue     Float?
  reportedAt      DateTime?

  @@unique([commandTargetId, kpiId])
}

model CommandStatusLog {
  id        String         @id @default(cuid())
  commandId String
  command   Command        @relation(fields: [commandId], references: [id], onDelete: Cascade)
  from      CommandStatus?
  to        CommandStatus
  byUserId  String?
  note      String?
  createdAt DateTime       @default(now())

  @@index([commandId, createdAt])
}

model DigitalSignature {
  id             String        @id @default(cuid())
  commandId      String
  command        Command       @relation(fields: [commandId], references: [id], onDelete: Cascade)
  signerId       String
  signer         User          @relation(fields: [signerId], references: [id])
  signatureType  SignatureType @default(E_SIGN)
  signatureData  String        @db.Text
  certificateRef String?
  signedAt       DateTime      @default(now())
  ipAddress      String?
  userAgent      String?
  valid          Boolean       @default(true)

  @@index([commandId])
  @@index([signerId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  commandId String?
  command   Command?            @relation(fields: [commandId], references: [id])
  missionId String?
  mission   Mission?            @relation(fields: [missionId], references: [id])
  channel   NotificationChannel
  subject   String
  body      String              @db.Text
  priority  MissionPriority     @default(NORMAL)
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

model EscalationRule {
  id           String            @id @default(cuid())
  name         String
  triggerOn    EscalationTrigger
  appliesTo    EscalationScope
  afterMinutes Int
  toRoleId     String?
  toRole       Role?             @relation(fields: [toRoleId], references: [id])
  toUserId     String?
  toUser       User?             @relation("EscalationToUser", fields: [toUserId], references: [id])
  toUnitParent Boolean           @default(false)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())

  logs EscalationLog[]
}

model EscalationLog {
  id             String         @id @default(cuid())
  ruleId         String
  rule           EscalationRule @relation(fields: [ruleId], references: [id])
  commandId      String?
  command        Command?       @relation(fields: [commandId], references: [id])
  missionId      String?
  mission        Mission?       @relation(fields: [missionId], references: [id])
  triggeredAt    DateTime       @default(now())
  notifiedUserId String?
  notifiedUser   User?          @relation(fields: [notifiedUserId], references: [id])
  resolved       Boolean        @default(false)
  resolvedAt     DateTime?

  @@index([ruleId, triggeredAt])
}

