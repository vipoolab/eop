// E. COMPLIANCE (TOR 5.4.3 / 3.1-3.3) — 5 models
// ═══════════════════════════════════════════════════════════════

model ComplianceTemplate {
  id            String             @id @default(cuid())
  standard      ComplianceStandard
  code          String             @unique
  name          String
  version       String
  effectiveDate DateTime
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())

  items   ComplianceChecklistItem[]
  reports ComplianceReport[]
}

model ComplianceChecklistItem {
  id               String             @id @default(cuid())
  templateId       String
  template         ComplianceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  code             String
  category         String
  question         String             @db.Text
  weight           Float              @default(1.0)
  order            Int                @default(0)
  evidenceRequired Boolean            @default(false)

  answers ComplianceAnswer[]

  @@unique([templateId, code])
  @@index([templateId, order])
}

model ComplianceReport {
  id                    String             @id @default(cuid())
  templateId            String
  template              ComplianceTemplate @relation(fields: [templateId], references: [id])
  unitId                String?
  unit                  Unit?              @relation(fields: [unitId], references: [id])
  period                String
  status                ReportStatus       @default(DRAFT)
  score                 Float?
  maxScore              Float?
  dueDate               DateTime?          // ครบกำหนดส่งหน่วยประเมินภายนอก (TOR ๓.๒)
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewerId            String?
  reviewer              User?              @relation("CompReportReviewer", fields: [reviewerId], references: [id])

  // Approval + e-Signature (TOR ๓.๑ — ผบ.หน่วยลงนาม)
  approverId            String?
  approver              User?              @relation("CompReportApprover", fields: [approverId], references: [id])
  approvedAt            DateTime?
  approverSignature     String?            @db.Text    // base64 image or hash
  signatureCertRef      String?                        // อ้างอิง cert (TDID/TDA) ถ้ามี
  signatureIp           String?
  signatureUa           String?

  externallySubmittedAt DateTime?
  createdById           String
  createdBy             User               @relation("CompReportCreator", fields: [createdById], references: [id])
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  answers   ComplianceAnswer[]
  scoreLogs ComplianceScoreLog[]

  @@index([templateId, period])
  @@index([dueDate, status])
  @@index([approverId])
}

model ComplianceAnswer {
  id             String                  @id @default(cuid())
  reportId       String
  report         ComplianceReport        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  itemId         String
  item           ComplianceChecklistItem @relation(fields: [itemId], references: [id])
  answer         String?                 @db.Text
  selfScore      Float?
  reviewerScore  Float?
  evidenceDocId  String?
  evidenceDoc    Document?               @relation(fields: [evidenceDocId], references: [id])
  assignedUnitId String?                                                     // TOR ๓.๒ — กระจายให้หน่วยตอบ
  answeredById   String?
  answeredBy     User?                   @relation(fields: [answeredById], references: [id])
  answeredAt     DateTime?

  @@unique([reportId, itemId])
}

model ComplianceScoreLog {
  id          String           @id @default(cuid())
  reportId    String
  report      ComplianceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  version     Int
  score       Float
  changedById String
  changedBy   User             @relation(fields: [changedById], references: [id])
  changedAt   DateTime         @default(now())
  note        String?

  @@index([reportId, version])
}

