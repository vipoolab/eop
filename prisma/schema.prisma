// EOP — Enterprise Operation Planning v3
// Database schema for สำนักงานยุทธศาสตร์ตำรวจ (สยศ.ตร.)
// Covers ALL 7 TOR programs (TOR 5.4.1 - 5.4.7) — see docs/DATABASE_DESIGN_v3.md
//
// Domain layout:
//   A. Identity & Access      (TOR 7.1, 5.5)
//   B. Strategic Plan         (TOR 5.4.1 / 1.1-1.3)
//   C. Agenda & Mission       (TOR 5.4.2 / 2.1-2.3)
//   D. Command & Workflow     (TOR 5.4.4 / 4.1-4.9)
//   E. Compliance             (TOR 5.4.3 / 3.1-3.3)
//   F. Data & AI              (TOR 5.4.6 / 6.1-6.10, 8.10)
//   G. Operations Intelligence (TOR 6.2, 6.5, 6.6, 6.9)
//   H. Resource & Performance  (TOR 6.10.10 ข.4, ข.5)
//   I. Incident, Audit, Privacy (TOR 6.4, 7.1.5, PDPA)

generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, pg_stat_statements, pgcrypto, uuidOssp(map: "uuid-ossp"), supabase_vault]
}

// ═══════════════════════════════════════════════════════════════
// ENUMS — 27 total (organized by domain)
// ═══════════════════════════════════════════════════════════════

// — IDENTITY (A) —
enum UserRole {
  ADMIN
  COMMANDER
  STAFF
  AUDITOR
  VIEWER
}

enum UnitLevel {
  NATIONAL
  REGION
  PROVINCE
  STATION
  DIVISION
}

enum UnitType {
  COMMAND
  OPERATION
  SUPPORT
  SPECIAL
}

enum MobilePlatform {
  IOS
  ANDROID
  WEB_PWA
}

enum LoginFailReason {
  WRONG_PASS
  USER_LOCKED
  MFA_FAIL
  UNKNOWN_USER
  ACCOUNT_DISABLED
}

// — STRATEGIC (B) —
enum PlanLevel {
  NATIONAL
  MASTER
  ACTION
}

enum PlanSource {
  OFFICIAL
  IMPORTED
  MANUAL
}

enum PlanStatus {
  DRAFT
  ACTIVE
  REVISED
  ARCHIVED
}

enum ImportFormat {
