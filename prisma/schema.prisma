// ═══════════════════════════════════════════════════════════════
// I. INCIDENT, AUDIT, PRIVACY (TOR 6.4, 7.1.5, PDPA) — 3 models
// ═══════════════════════════════════════════════════════════════

model Incident {
  id               String          @id @default(cuid())
  code             String          @unique
  type             String
  title            String
  description      String?
  lat              Float?
  lng              Float?
  location         String?
  severity         Int             @default(5)
  status           String          @default("open")
  assignedUnitId   String?
  assignedUnit     Unit?           @relation(fields: [assignedUnitId], references: [id])
  respondedById    String?
  respondedBy      User?           @relation(fields: [respondedById], references: [id])
  respondedAt      DateTime?
  missionId        String?
